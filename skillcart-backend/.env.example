# =========================================================================
# SkillCart Production Environment Variables Template (.env.example)
# Rename this file to .env and configure the values for your environment.
# =========================================================================

# -------------------------------------------------------------------------
# Server configuration
# -------------------------------------------------------------------------
# PORT: The port number the Spring Boot application runs on (Render/Heroku override this automatically)
PORT=8080

# -------------------------------------------------------------------------
# Database Configuration (MySQL / PostgreSQL / AWS RDS / PlanetScale)
# -------------------------------------------------------------------------
# SPRING_DATASOURCE_URL: Complete JDBC URL pointing to the production database
SPRING_DATASOURCE_URL=jdbc:mysql://<prod-db-host>:<port>/skillcart?useSSL=true&requireSSL=true

# SPRING_DATASOURCE_USERNAME: Database username for authentication
SPRING_DATASOURCE_USERNAME=<db-username>

# SPRING_DATASOURCE_PASSWORD: Database password for authentication
SPRING_DATASOURCE_PASSWORD=<db-password>

# -------------------------------------------------------------------------
# Security Configuration (JWT Token Management)
# -------------------------------------------------------------------------
# JWT_SECRET: A cryptographically secure random secret key (minimum 256-bit / 32 characters)
JWT_SECRET=<your-long-secure-random-32-plus-character-secret>

# JWT_EXPIRATION: Token expiration time in milliseconds (e.g. 86400000 = 24 Hours)
JWT_EXPIRATION=86400000

# -------------------------------------------------------------------------
# Payment Gateway Configuration (Razorpay Integration)
# -------------------------------------------------------------------------
# RAZORPAY_KEY_ID: The public API key ID from your Razorpay Dashboard
RAZORPAY_KEY_ID=rzp_live_<your-live-key-id>

# RAZORPAY_KEY_SECRET: The private API key secret from your Razorpay Dashboard
RAZORPAY_KEY_SECRET=<your-live-key-secret>

# -------------------------------------------------------------------------
# Frontend URL Configuration (CORS Configuration)
# -------------------------------------------------------------------------
# FRONTEND_URL: The absolute URL of your hosted React application for CORS validation
FRONTEND_URL=https://<your-app-domain>.vercel.app

# -------------------------------------------------------------------------
# Admin User Seeding Configuration
# -------------------------------------------------------------------------
# ADMIN_NAME: Name of the default admin user seeded on database initialization
ADMIN_NAME=Admin

# ADMIN_EMAIL: Email address of the default admin user
ADMIN_EMAIL=admin@yourdomain.com

# ADMIN_PASSWORD: Password of the default admin user (change on first login!)
ADMIN_PASSWORD=<secure-admin-password>

# -------------------------------------------------------------------------
# Data Seeding Options
# -------------------------------------------------------------------------
# SEED_DEMO_COURSES: If true, inserts default courses on start (Set to false in production)
SEED_DEMO_COURSES=false
